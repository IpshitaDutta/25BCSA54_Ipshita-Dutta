package com.thirdprog;
import java.util.Scanner;
public class sumn {
public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		int n;
		System.out.println("Enter a positive number else enter negative number to stop");
		n=sc.nextInt();
		int s=0;
		while(n>=0)
		{
			s=s+n;
			System.out.println("Enter a positive number else enter negative number to stop");
			n=sc.nextInt();
		}
System.out.println("Sum="+s);
	}

}
